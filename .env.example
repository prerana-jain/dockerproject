# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=appdb
MYSQL_USER=app
MYSQL_PASSWORD=change_me_app

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=3000

# ── Frontend ─────────────────────────────────────────────────────────────────
# Port exposed on the host (browser access)
FRONTEND_PORT=8080
